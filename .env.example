# ── Binance API ────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Set to false for mainnet (REAL money — be careful!)
USE_TESTNET=true

# live | paper
BINANCE_MODE=live

# ── Dashboard Auth ─────────────────────────────────────────────────────────────
DASHBOARD_USER=your_username
DASHBOARD_PASS=your_password

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_64_char_random_hex_string

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── News Engine ────────────────────────────────────────────────────────────────
# Set to true to start the news engine on server boot
NEWS_ENGINE=false

# ── Rate Limits (optional overrides) ──────────────────────────────────────────
# RATE_TRADE=120/minute
# RATE_SIGNAL=60/minute
# RATE_TWAP=20/minute
# RATE_READ=120/minute

# ── CORS (optional override) ───────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
